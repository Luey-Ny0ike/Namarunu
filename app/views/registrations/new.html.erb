<section class="auth-shell py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-10 col-md-8 col-lg-6">
        <div class="card auth-card">
          <div class="card-body p-4 p-md-5">
            <h1 class="auth-title mb-2">Create your account</h1>
            <p class="text-muted mb-4">Start building your store in minutes.</p>

            <% if flash[:alert] %>
              <div class="alert alert-danger py-2" role="alert">
                <%= flash[:alert] %>
              </div>
            <% end %>

            <%= form_with model: @user, url: registration_path, class: "auth-form" do |form| %>
              <div class="row">
                <div class="col-12 col-md-6 mb-3">
                  <%= form.label :full_name, "Full name", class: "form-label" %>
                  <%= form.text_field :full_name, required: true, autocomplete: "name", placeholder: "Jane Doe", class: "form-control" %>
                </div>
                <div class="col-12 col-md-6 mb-3">
                  <%= form.label :phone_number, "Phone number", class: "form-label" %>
                  <%= form.telephone_field :phone_number, autocomplete: "tel", placeholder: "+1 415 555 0123", class: "form-control" %>
                </div>
              </div>
              <div class="mb-3">
                <%= form.label :email_address, "Email address", class: "form-label" %>
                <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "name@store.com", class: "form-control" %>
              </div>
              <div class="mb-3">
                <%= form.label :password, "Password", class: "form-label" %>
                <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Create a password", maxlength: 72, class: "form-control" %>
              </div>
              <div class="mb-3">
                <%= form.label :password_confirmation, "Confirm password", class: "form-label" %>
                <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", maxlength: 72, class: "form-control" %>
              </div>
              <div class="d-grid">
                <%= form.submit "Create account", class: "btn btn-namarunu" %>
              </div>
            <% end %>

            <div class="auth-meta mt-4 text-center">
              <span class="text-muted">Already have an account?</span>
              <%= link_to "Sign in", new_session_path, class: "auth-link ms-2" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
