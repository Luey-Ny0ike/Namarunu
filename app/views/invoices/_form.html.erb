<% plans_json = plans.each_with_object({}) { |p, h|
     h[p.code] = { name: p.name, plan_type: p.plan_type, prices: p.prices }
   }.to_json %>

<%= form_with model: invoice,
      data: { controller: "line-items",
              "line-items-currency-value": invoice.currency.presence || "KES",
              "line-items-plans-value": plans_json } do |f| %>

  <%# Hidden totals fields — updated by Stimulus before submit %>
  <%= f.hidden_field :subtotal_cents,    data: { "line-items-target": "subtotalCents" } %>
  <%= f.hidden_field :tax_cents,         data: { "line-items-target": "taxCents" } %>
  <%= f.hidden_field :total_cents,       data: { "line-items-target": "totalCents" } %>
  <%= f.hidden_field :amount_due_cents,  data: { "line-items-target": "amountDueCents" } %>
  <%= f.hidden_field :amount_paid_cents, value: invoice.amount_paid_cents.to_i %>
  <%= f.hidden_field :discount_cents,    value: invoice.discount_cents.to_i %>

  <%# Page header — title + subtitle only %>
  <div class="mb-4">
    <h1 class="h4 fw-bold mb-1"><%= invoice.persisted? ? "Edit Invoice" : "Create New Invoice" %></h1>
    <p class="text-muted small mb-0">Drafting invoice #<%= next_invoice_number %></p>
  </div>

  <% if invoice.errors.any? %>
    <div class="alert alert-danger mb-4">
      <ul class="mb-0">
        <% invoice.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Recipient + Contact %>
  <div class="card shadow-sm mb-3"
       data-controller="autocomplete"
       data-autocomplete-url-value="<%= stores_path(format: :json) %>"
       data-autocomplete-param-value="q"
       data-autocomplete-min-length-value="2">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Name</label>
          <div class="position-relative">
            <%= f.text_field :name,
                  class: "form-control",
                  placeholder: "Search store or type a name",
                  autocomplete: "off",
                  data: {
                    autocomplete_target: "input",
                    autocomplete_fills_name: true,
                    action: "input->autocomplete#clear input->autocomplete#search blur->autocomplete#clear"
                  } %>
            <ul class="list-group position-absolute w-100 z-3 shadow-sm d-none"
                data-autocomplete-target="results"></ul>
            <%= f.hidden_field :store_id, data: { autocomplete_target: "hidden" } %>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Contact Email</label>
          <%= f.email_field :email_address,
                class: "form-control",
                placeholder: "billing@example.com",
                data: { autocomplete_fills_email: true } %>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Phone Number</label>
          <%= f.telephone_field :phone_number,
                class: "form-control",
                placeholder: "+254700000000",
                data: { autocomplete_fills_phone: true } %>
        </div>
      </div>
    </div>
  </div>

  <%# Dates %>
  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Date of Issue</label>
          <%= f.date_field :issued_at, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Invoice Date</label>
          <%= f.date_field :billing_period_start, class: "form-control" %>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Due Date</label>
          <%= f.date_field :due_at, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>

  <%# Plan accordion — above line items %>
  <div class="accordion shadow-sm mb-3" id="planAccordion">
    <div class="accordion-item">
      <h2 class="accordion-header">
        <button class="accordion-button <%= invoice.plan_code.present? ? '' : 'collapsed' %> py-2"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#planSection"
                aria-expanded="<%= invoice.plan_code.present? %>"
                aria-controls="planSection">
          <small class="fw-semibold text-muted">Plan <span class="fw-normal">(optional — selecting a plan fills the first line item)</span></small>
        </button>
      </h2>
      <div id="planSection"
           class="accordion-collapse collapse <%= invoice.plan_code.present? ? 'show' : '' %>"
           data-bs-parent="#planAccordion">
        <div class="accordion-body">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Plan</label>
              <%= f.select :plan_code,
                    plans.map { |p| [p.name, p.code] },
                    { include_blank: "— None —" },
                    class: "form-select form-select-sm",
                    data: { action: "change->line-items#planChanged" } %>
            </div>
            <div class="col-md-4">
              <label class="form-label">Plan Type</label>
              <%= f.select :plan_type,
                    Invoice::PLAN_TYPES.map { |t| [t.capitalize, t] },
                    { include_blank: "— None —" },
                    class: "form-select form-select-sm",
                    data: { plan_type_select: true } %>
            </div>
            <div class="col-md-4">
              <label class="form-label">Billing Period</label>
              <%= f.select :billing_period,
                    [["—", ""]] + Invoice::BILLING_PERIODS.map { |b| [b.humanize, b] },
                    {},
                    class: "form-select form-select-sm",
                    data: { billing_period_select: true } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Line Items %>
  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <h6 class="fw-bold mb-3">Line Items</h6>

      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr class="text-uppercase text-muted small">
            <th style="width:40%">Description</th>
            <th class="text-end" style="width:12%">Quantity</th>
            <th class="text-end" style="width:18%">Price</th>
            <th class="text-end" style="width:18%">Amount</th>
            <th style="width:12%"></th>
          </tr>
        </thead>
        <tbody data-line-items-target="rows">
          <%= f.fields_for :line_items do |li_f| %>
            <%= render "line_item_fields", f: li_f, currency: invoice.currency %>
          <% end %>
        </tbody>
      </table>

      <%# Template row cloned by JS for new line items %>
      <template data-line-items-target="template">
        <tr data-line-item-row>
          <td>
            <select name="invoice[line_items_attributes][LINE_ITEM_INDEX][kind]"
                    class="form-select form-select-sm mb-1"
                    data-kind-select
                    data-action="change->line-items#kindChanged">
              <option value="subscription">Subscription</option>
              <option value="setup_fee">Setup fee</option>
              <option value="addon" selected>Addon</option>
              <option value="discount">Discount</option>
              <option value="tax">Tax</option>
            </select>
            <input type="text"
                   name="invoice[line_items_attributes][LINE_ITEM_INDEX][description]"
                   class="form-control form-control-sm"
                   placeholder="Item description..."
                   data-description-input>
          </td>
          <td>
            <input type="number"
                   name="invoice[line_items_attributes][LINE_ITEM_INDEX][quantity]"
                   class="form-control form-control-sm text-end"
                   value="1" min="1"
                   data-qty-input
                   data-action="input->line-items#calculate">
          </td>
          <td>
            <input type="number"
                   class="form-control form-control-sm text-end"
                   value="0.00" step="0.01" min="0"
                   data-price-input
                   data-action="input->line-items#calculate">
            <input type="hidden"
                   name="invoice[line_items_attributes][LINE_ITEM_INDEX][unit_amount_cents]"
                   value="0"
                   data-unit-amount-cents-input>
          </td>
          <td class="text-end">
            <span data-amount-display>0.00</span>
            <input type="hidden"
                   name="invoice[line_items_attributes][LINE_ITEM_INDEX][amount_cents]"
                   value="0"
                   data-amount-cents-input>
          </td>
          <td class="text-center">
            <button type="button"
                    class="btn btn-sm btn-link text-muted p-0"
                    data-action="line-items#remove"
                    title="Remove">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
              </svg>
            </button>
          </td>
        </tr>
      </template>

      <div class="mt-3">
        <button type="button"
                class="btn btn-sm btn-link text-success px-0 fw-semibold"
                data-action="line-items#add">
          + Add Line Item
        </button>
      </div>
    </div>
  </div>

  <%# Notes + Totals %>
  <div class="row g-3 mb-4">
    <div class="col-lg-7">
      <div class="card shadow-sm h-100">
        <div class="card-body d-flex flex-column">
          <label class="form-label fw-semibold">Notes &amp; Terms</label>
          <%= f.text_area :notes, class: "form-control border-0 flex-grow-1 p-0",
                rows: 4,
                placeholder: "Thank you for your business. Please pay within 30 days." %>
        </div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <span class="text-muted">Subtotal</span>
            <span data-line-items-target="subtotal">0.00</span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted d-flex align-items-center gap-1">
              Tax
              <input type="number"
                     value="0"
                     min="0" max="100" step="0.1"
                     class="form-control form-control-sm"
                     style="width:60px"
                     data-line-items-target="taxRate"
                     data-action="input->line-items#calculate">
              %
            </span>
            <span data-line-items-target="taxAmount">0.00</span>
          </div>
          <hr class="my-2">
          <div class="d-flex justify-content-between fw-bold">
            <span>Grand Total</span>
            <span class="text-success fs-5" data-line-items-target="grandTotal">0.00</span>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mt-3">
        <div class="card-body">
          <div class="row g-2">
            <div class="col-6">
              <label class="form-label small text-muted">Currency</label>
              <%= f.select :currency,
                    Store::CURRENCIES.map { |c| [c, c] },
                    {},
                    class: "form-select form-select-sm",
                    required: true,
                    data: { autocomplete_fills_currency: true,
                            currency_select: true,
                            action: "change->line-items#currencyChanged" } %>
            </div>
            <div class="col-6">
              <label class="form-label small text-muted">Billing Period End</label>
              <%= f.date_field :billing_period_end, class: "form-control form-control-sm" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Submit buttons at bottom %>
  <div class="d-flex gap-2 justify-content-end mb-4">
    <% if invoice.persisted? %>
      <%= link_to "Preview", invoice_path(invoice), class: "btn btn-outline-secondary", target: "_blank" %>
    <% end %>
    <%= link_to "Discard", invoice.persisted? ? invoice_path(invoice) : invoices_path,
          class: "btn btn-outline-danger" %>
    <%= f.submit "Save Draft",   name: "save_as", value: "draft",  class: "btn btn-dark" %>
    <%= f.submit "Save Invoice", name: "save_as", value: "issued", class: "btn btn-success" %>
  </div>

<% end %>
