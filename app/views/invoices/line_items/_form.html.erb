<%= form_with model: [invoice, line_item] do |f| %>
  <% if line_item.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% line_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Kind</label>
      <%= f.select :kind,
            Invoice::LineItem::KINDS.map { |k| [k.humanize, k] },
            { include_blank: "Select kind…" },
            class: "form-select",
            required: true %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Quantity</label>
      <%= f.number_field :quantity, class: "form-control", min: 1, step: 1, required: true %>
    </div>

    <div class="col-12">
      <label class="form-label">Description</label>
      <%= f.text_field :description, class: "form-control", required: true %>
    </div>

    <div class="col-md-6">
      <label class="form-label">Unit Amount (in cents)</label>
      <%= f.number_field :unit_amount_cents, class: "form-control", min: 0, step: 1, required: true %>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= f.submit line_item.persisted? ? "Update" : "Add Line Item", class: "btn btn-primary btn-sm" %>
    <%= link_to "Cancel", invoice_path(invoice), class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>
