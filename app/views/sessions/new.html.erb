<section class="auth-shell py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-10 col-md-7 col-lg-5">
        <div class="card auth-card">
          <div class="card-body p-4 p-md-5">
            <h1 class="auth-title mb-2">Welcome back</h1>
            <p class="text-muted mb-4">Sign in to manage your store.</p>

            <% if flash[:alert] %>
              <div class="alert alert-danger py-2" role="alert">
                <%= flash[:alert] %>
              </div>
            <% end %>
            <% if flash[:notice] %>
              <div class="alert alert-success py-2" role="alert">
                <%= flash[:notice] %>
              </div>
            <% end %>

            <%= form_with url: session_path, class: "auth-form" do |form| %>
              <div class="mb-3">
                <%= form.label :email_address, "Email address", class: "form-label" %>
                <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "name@store.com", value: params[:email_address], class: "form-control" %>
              </div>
              <div class="mb-3">
                <%= form.label :password, "Password", class: "form-label" %>
                <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "form-control" %>
              </div>
              <div class="d-grid">
                <%= form.submit "Sign in", class: "btn btn-namarunu" %>
              </div>
            <% end %>

            <div class="auth-meta mt-4 text-center">
              <%= link_to "Forgot password?", new_password_path, class: "auth-link" %>
              <span class="text-muted mx-2">•</span>
              <%= link_to "Create an account", new_registration_path, class: "auth-link" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
