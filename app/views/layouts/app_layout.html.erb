<!DOCTYPE html>
<html>
  <head>
    <title>Namarunu CRM</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "Namarunu CRM", app_root_path, class: "navbar-brand fw-semibold text-white" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNavbar" aria-controls="appNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="appNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><%= nav_link_to "My Day", app_root_path %></li>
            <li class="nav-item"><%= nav_link_to "Demos", app_demos_path, match: :prefix %></li>
            <li class="nav-item"><%= nav_link_to "Leads", app_leads_path, match: :prefix %></li>
            <li class="nav-item"><%= nav_link_to "Inquiries", inquiries_path, match: :prefix %></li>
          </ul>
          <%= link_to "Log out", session_path, data: { turbo_method: :delete }, class: "btn btn-outline-light btn-sm fw-semibold" %>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == "alert" ? "danger" : "success" %>" role="alert">
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
