<!DOCTYPE html>
<html>
  <head>
    <title>Namarunu Contributor Portal</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
      <div class="container">
        <%= link_to "Contributor Portal", contribute_root_path, class: "navbar-brand fw-semibold" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#contributeNavbar" aria-controls="contributeNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="contributeNavbar">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><%= link_to "Submit Lead", new_contribute_submission_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "My Leads", contribute_submissions_path, class: "nav-link" %></li>
          </ul>
          <%= link_to "Log out", session_path, data: { turbo_method: :delete }, class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% flash.each do |type, message| %>
        <div class="alert alert-<%= type == "alert" ? "danger" : "success" %>" role="alert">
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
