<% primary_contact = lead.lead_contacts.first %>
<% overdue = lead.next_action_at.present? && lead.next_action_at < Time.current %>
<% closed = lead.status_won? || lead.status_lost? %>
<% status_badge_class = lead_status_badge_class(lead.status) %>
<% temperature_badge_class = lead_temperature_badge_class(lead.temperature) %>

<div class="card shadow-sm <%= 'border-start border-3 border-danger' if overdue %> <%= 'opacity-75' if closed %>">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
      <div class="fw-semibold"><%= lead.business_name %></div>
      <div class="d-flex align-items-center gap-1 flex-wrap justify-content-end">
        <span class="badge <%= status_badge_class %>"><%= lead.status.humanize %></span>
        <span class="badge <%= temperature_badge_class %>"><%= lead.temperature.humanize %></span>
      </div>
    </div>

    <div class="small text-muted mb-2"><%= lead.industry.presence || "-" %> • <%= lead.location.presence || "-" %></div>

    <div class="small mb-1">
      <span class="text-muted">Contact:</span>
      <%= primary_contact&.name.presence || "-" %>
      <% if primary_contact&.phone.present? || primary_contact&.email.present? %>
        <span class="text-muted">· <%= primary_contact.phone.presence || primary_contact.email %></span>
      <% end %>
    </div>

    <div class="small mb-1">
      <span class="text-muted">Assigned to:</span>
      <%= lead.owner_user&.full_name || lead.owner_user&.email_address || "Unassigned" %>
    </div>

    <div class="small mb-3">
      <span class="text-muted">Next:</span>
      <% if lead.next_action_at.present? %>
        <%= l(lead.next_action_at, format: :short) %>
        <% if overdue %>
          <span class="badge bg-danger-subtle text-danger-emphasis ms-1">Overdue</span>
        <% end %>
      <% else %>
        -
      <% end %>
    </div>

    <div>
      <%= link_to "Open", app_lead_path(lead, return_to: request.fullpath), class: "btn btn-namarunu btn-sm", data: { turbo_frame: "_top" } %>
    </div>
  </div>
</div>
