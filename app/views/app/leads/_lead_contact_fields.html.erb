<div class="border rounded-3 p-3 mb-3 bg-light" data-lead-contact-row>
  <%= form.hidden_field :id if form.object.persisted? %>
  <%= form.hidden_field :_destroy, value: "0" %>

  <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
    <h3 class="h6 mb-0">Contact</h3>
    <button type="button" class="btn btn-sm btn-outline-danger" data-action="lead-contacts#remove">Remove</button>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= form.label :role, class: "form-label" %>
      <%= form.text_field :role, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :phone, class: "form-label" %>
      <%= form.telephone_field :phone, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :preferred_channel, class: "form-label" %>
      <%= form.select :preferred_channel,
                      LeadContact::CHANNEL_OPTIONS.map { |value| [value.humanize, value] },
                      { include_blank: "No preference" },
                      class: "form-select" %>
    </div>
    <div class="col-12">
      <p class="small text-muted mb-0">Provide at least phone or email.</p>
    </div>
  </div>
</div>
