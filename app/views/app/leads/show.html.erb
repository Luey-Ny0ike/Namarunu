<% status_badge_class = lead_status_badge_class(@lead.status) %>
<% temperature_badge_class = lead_temperature_badge_class(@lead.temperature) %>
<% manager_like = Current.user&.sales_manager? || Current.user&.super_admin? %>
<% requested_return_to = params[:return_to].to_s %>
<% leads_return_to = requested_return_to.start_with?("/app/leads") ? requested_return_to : nil %>
<% back_to_leads_path = leads_return_to.presence || app_leads_path %>
<% show_return_to_path = leads_return_to.present? ? app_lead_path(@lead, return_to: leads_return_to) : app_lead_path(@lead) %>

<style>
  @media (min-width: 992px) {
    .lead-show-sticky {
      position: sticky;
      top: 5rem;
    }
  }
</style>

<% if notice.present? %>
  <div class="alert alert-info" role="alert" id="notice"><%= notice %></div>
<% end %>
<% if alert.present? %>
  <div class="alert alert-warning" role="alert"><%= alert %></div>
<% end %>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
      <div>
        <h1 class="h3 mb-2"><%= @lead.business_name %></h1>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <span class="badge <%= status_badge_class %>"><%= @lead.status.humanize %></span>
          <span class="badge <%= temperature_badge_class %>"><%= @lead.temperature.humanize %></span>
        </div>
        <p class="small text-muted mb-0">
          <span><strong>Location:</strong> <%= @lead.location.presence || "-" %></span>
          <span class="mx-2">|</span>
          <span><strong>Source:</strong> <%= @lead.source.presence || "-" %></span>
        </p>
      </div>

      <div class="d-grid d-sm-flex gap-2 align-self-stretch align-self-lg-start">
        <%= link_to "Back to Leads", back_to_leads_path, class: "btn btn-outline-secondary" %>
        <% if @lead.converted_account.present? %>
          <%= link_to "View Account", app_account_path(@lead.converted_account), class: "btn btn-outline-secondary" %>
        <% end %>
        <% if policy(@lead).edit? %>
          <%= link_to "Edit", edit_app_lead_path(@lead), class: "btn btn-namarunu" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 g-lg-4">
  <div class="col-12 col-lg-7 order-2 order-lg-1">
    <div class="d-flex flex-column gap-3 gap-lg-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h5 mb-0">Demos</h2>
            <% if policy(@lead).update? %>
              <button id="book-demo" class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#leadBookDemoModal">Book demo</button>
            <% end %>
          </div>
          <% if @demos.any? %>
            <div class="list-group list-group-flush">
              <% @demos.each do |demo| %>
                <div class="list-group-item px-0">
                  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div>
                      <div class="fw-semibold"><%= l(demo.scheduled_at, format: :short) %> - <%= demo.status.humanize %></div>
                      <div class="small text-muted">
                        Duration: <%= demo.duration_minutes %> min
                        - Assignee: <%= demo.assigned_to_user&.full_name.presence || demo.assigned_to_user&.email_address || "-" %>
                      </div>
                    </div>
                    <%= link_to "Open", app_demo_path(demo), class: "btn btn-outline-secondary btn-sm" %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">No demos booked for this lead yet.</p>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h5 mb-3">Activity Timeline</h2>
          <% if @activities.any? %>
            <div class="list-group list-group-flush">
              <% @activities.each do |activity| %>
                <% title = case activity.action_type
                  when "call_logged" then "Call logged"
                  when "demo_booked" then "Demo booked"
                  when "demo_completed" then "Demo completed"
                  when "invoice_sent" then "Invoice sent"
                  when "won" then "Marked won"
                  when "lost" then "Marked lost"
                  when "status_changed" then "Status changed"
                  when "checked_out" then "Checked out"
                  when "released" then "Checkout released"
                  when "converted" then "Converted to account"
                  else activity.timeline_label
                end %>
                <div class="list-group-item px-0">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                      <div class="fw-semibold"><%= title %></div>
                      <div class="small text-muted">by <%= activity.actor_user.full_name.presence || activity.actor_user.email_address %></div>

                      <% if activity.action_type == "call_logged" %>
                        <div class="small mt-1">
                          <span class="badge bg-light text-dark border">
                            Outcome: <%= activity.metadata["outcome"].presence&.humanize || "Unknown" %>
                          </span>
                        </div>
                        <% if manager_like && activity.metadata["notes"].present? %>
                          <details class="small mt-1">
                            <summary class="text-muted" role="button">View notes</summary>
                            <div class="mt-1"><%= activity.metadata["notes"] %></div>
                          </details>
                        <% end %>
                      <% end %>

                      <% if activity.action_type == "status_changed" %>
                        <% from_status = activity.metadata["from"].presence || "-" %>
                        <% to_status = activity.metadata["to"].presence || "-" %>
                        <div class="small mt-1 text-muted"><%= from_status.to_s.humanize %> -> <%= to_status.to_s.humanize %></div>
                      <% end %>

                      <% if activity.action_type == "demo_booked" && activity.metadata["scheduled_at"].present? %>
                        <% scheduled_at = Time.zone.parse(activity.metadata["scheduled_at"].to_s) rescue nil %>
                        <% if scheduled_at.present? %>
                          <div class="small mt-1 text-muted">Scheduled: <%= l(scheduled_at, format: :short) %></div>
                        <% end %>
                      <% end %>

                      <% if manager_like && activity.metadata["changed_fields"].present? %>
                        <details class="small mt-1">
                          <summary class="text-muted" role="button">View details</summary>
                          <div class="mt-1">Changed fields: <%= activity.metadata["changed_fields"].join(", ") %></div>
                        </details>
                      <% end %>
                    </div>
                    <div class="small text-muted text-nowrap"><%= l(activity.occurred_at, format: :short) %></div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">No activity yet.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-5 order-1 order-lg-2">
    <div class="d-flex flex-column gap-3 gap-lg-4 lead-show-sticky">
      <%= render "app/leads/overview", lead: @lead, active_assignment: @active_assignment, latest_submission: @latest_submission, assignable_users: @assignable_users %>

      <div class="card shadow-sm" id="call-attempt">
        <div class="card-body">
          <h2 class="h5 mb-3">Actions</h2>

          <% if policy(@lead).convert? && !Current.user.sales_rep? %>
            <div class="d-grid mb-3">
              <%= button_to "Convert Lead", convert_app_lead_path(@lead), method: :post, class: "btn btn-success" %>
            </div>
          <% end %>

          <% if policy(@lead).update? %>
            <div class="border rounded-3 p-3 mb-3">
              <h3 class="h6 mb-3">Engagement</h3>
              <div class="d-grid gap-2">
                <button id="call-attempt-trigger" class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#leadLogAttemptModal">Log attempt</button>
              </div>
            </div>

            <div class="border rounded-3 p-3 mb-3">
              <h3 class="h6 mb-3">Post-Demo Actions</h3>
              <div class="d-grid gap-2">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#leadAwaitingCommitmentModal">Awaiting commitment</button>
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#leadInvoiceSentModal">Mark invoice sent</button>
                <button class="btn btn-outline-success" type="button" data-bs-toggle="modal" data-bs-target="#leadConfirmPaymentModal">Confirm payment (won)</button>
                <button class="btn btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#leadMarkLostModal">Mark lost</button>
              </div>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>

<% if policy(@lead).update? %>
  <div class="d-lg-none" style="height: 4.5rem;"></div>
  <div class="d-lg-none position-sticky bottom-0 bg-light border-top py-2 mt-3" style="z-index: 1020;">
    <div class="d-flex gap-2">
      <button class="btn btn-outline-primary flex-fill" type="button" data-bs-toggle="modal" data-bs-target="#leadLogAttemptModal">Log attempt</button>
      <button class="btn btn-outline-primary flex-fill" type="button" data-bs-toggle="modal" data-bs-target="#leadBookDemoModal">Book demo</button>
      <button class="btn btn-dark flex-fill" type="button" data-bs-toggle="offcanvas" data-bs-target="#leadMobileMoreActions" aria-controls="leadMobileMoreActions">More</button>
    </div>
  </div>
<% end %>

<div class="modal fade" id="leadLogAttemptModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Log Attempt</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: log_attempt_app_lead_path(@lead), method: :post, local: true, class: "d-grid gap-2" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.select :outcome,
                          options_for_select(Lead::CALL_OUTCOMES.keys.map { |value| [value.to_s.humanize, value] }),
                          { include_blank: "Select outcome" },
                          class: "form-select",
                          required: true,
                          data: { log_attempt_outcome: true } %>
          <div class="d-none" data-follow-up-wrapper>
            <%= form.label :next_action_at, "Follow-up at", class: "form-label small text-muted mb-1" %>
            <%= form.datetime_local_field :next_action_at, class: "form-control", data: { follow_up_input: true } %>
          </div>
          <%= form.text_area :notes, class: "form-control", rows: 3, placeholder: "Optional notes" %>
          <%= form.submit "Save Attempt", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="leadBookDemoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Book Demo</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: book_demo_app_lead_path(@lead), method: :post, local: true, class: "d-grid gap-2" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.label :scheduled_at, "Scheduled at", class: "form-label small text-muted mb-1" %>
          <%= form.datetime_local_field :scheduled_at, class: "form-control", required: true %>
          <%= form.label :duration_minutes, "Duration (minutes)", class: "form-label small text-muted mb-1 mt-1" %>
          <%= form.number_field :duration_minutes, class: "form-control", min: 1, step: 1, value: 30, required: true %>
          <% if manager_like %>
            <%= form.label :assigned_to_user_id, "Assign to", class: "form-label small text-muted mb-1 mt-1" %>
            <%= form.select :assigned_to_user_id,
                            options_for_select(@assignable_users.map { |user| [user.full_name.presence || user.email_address, user.id] }, Current.user.id),
                            {},
                            class: "form-select" %>
          <% end %>
          <%= form.label :notes, class: "form-label small text-muted mb-1 mt-1" %>
          <%= form.text_area :notes, class: "form-control", rows: 3, placeholder: "Optional prep notes" %>
          <%= form.submit "Book Demo", class: "btn btn-primary mt-1" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="leadAwaitingCommitmentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Mark Awaiting Commitment</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: mark_awaiting_commitment_app_lead_path(@lead), method: :post, local: true, class: "d-grid" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.submit "Confirm", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="offcanvas offcanvas-bottom h-auto d-lg-none" tabindex="-1" id="leadMobileMoreActions" aria-labelledby="leadMobileMoreActionsLabel">
  <div class="offcanvas-header">
    <h2 class="offcanvas-title h5 mb-0" id="leadMobileMoreActionsLabel">More Actions</h2>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body pt-0">
    <div class="d-grid gap-2">
      <button class="btn btn-outline-primary" type="button" data-bs-dismiss="offcanvas" data-bs-toggle="modal" data-bs-target="#leadAwaitingCommitmentModal">Awaiting commitment</button>
      <button class="btn btn-outline-primary" type="button" data-bs-dismiss="offcanvas" data-bs-toggle="modal" data-bs-target="#leadInvoiceSentModal">Mark invoice sent</button>
      <button class="btn btn-outline-success" type="button" data-bs-dismiss="offcanvas" data-bs-toggle="modal" data-bs-target="#leadConfirmPaymentModal">Confirm payment (won)</button>
      <button class="btn btn-outline-danger" type="button" data-bs-dismiss="offcanvas" data-bs-toggle="modal" data-bs-target="#leadMarkLostModal">Mark lost</button>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function () {
    var outcomeSelect = document.querySelector("[data-log-attempt-outcome='true']");
    var followUpWrapper = document.querySelector("[data-follow-up-wrapper]");
    var followUpInput = document.querySelector("[data-follow-up-input='true']");
    if (!outcomeSelect || !followUpWrapper || !followUpInput) return;

    var toggleFollowUp = function () {
      var isFollowUp = outcomeSelect.value === "follow_up";
      followUpWrapper.classList.toggle("d-none", !isFollowUp);
      followUpInput.required = isFollowUp;
      if (!isFollowUp) followUpInput.value = "";
    };

    toggleFollowUp();
    if (outcomeSelect.dataset.followUpBound !== "true") {
      outcomeSelect.addEventListener("change", toggleFollowUp);
      outcomeSelect.dataset.followUpBound = "true";
    }
  });
</script>

<div class="modal fade" id="leadInvoiceSentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Mark Invoice Sent</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: mark_invoice_sent_app_lead_path(@lead), method: :post, local: true, class: "d-grid" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.submit "Confirm", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="leadMarkLostModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Mark Lead Lost</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: mark_lost_app_lead_path(@lead), method: :post, local: true, class: "d-grid gap-2" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.select :lost_reason,
                          options_for_select(Lead::LOST_REASONS.keys.map { |value| [value.to_s.humanize, value] }),
                          { include_blank: "Select lost reason" },
                          class: "form-select",
                          required: true %>
          <%= form.submit "Mark Lost", class: "btn btn-danger" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="leadConfirmPaymentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Confirm Payment</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with url: confirm_payment_app_lead_path(@lead), method: :post, local: true, class: "d-grid" do |form| %>
          <%= form.hidden_field :return_to, value: show_return_to_path %>
          <%= form.submit "Confirm Payment (Mark Won)", class: "btn btn-success" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
