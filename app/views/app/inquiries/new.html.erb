<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1">New Inquiry</h1>
      <p class="text-muted mb-0">Add a new inquiry to the list.</p>
    </div>
    <%= link_to 'Back', app_inquiries_path, class: 'btn btn-outline-secondary' %>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
      <div class="card shadow-sm">
        <div class="card-body">
          <%= render "app/inquiries/form", inquiry: @inquiry %>
        </div>
      </div>
    </div>
  </div>
</div>
