  <% form_options = {
    model: inquiry,
    url: inquiry.new_record? ? app_inquiries_path : app_inquiry_path(inquiry),
    local: true
  } %>
  <% if inquiry.new_record? %>
    <% form_options[:data] = { controller: "recaptcha", action: "submit->recaptcha#submit", recaptcha_function_value: "executeRecaptchaForInquirySubmitAsync" } %>
  <% end %>
  <%= form_with(**form_options) do |form| %>
    <% if inquiry.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(inquiry.errors.count, "error") %> prohibited this inquiry from being saved:</h2>

        <ul>
          <% inquiry.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="row g-3">
      <div class="field col-md-12">
        <%= form.label :full_name %>
        <%= form.text_field :full_name, class: "form-control" %>
      </div>

      <div class="field col-md-6">
        <%= form.label :phone_number %>
        <%= form.text_field :phone_number, class: "form-control" %>
      </div>

      <div class="field col-md-6">
        <%= form.label :email %>
        <%= form.text_field :email, class: "form-control" %>
      </div>

      <div class="field col-md-12">
        <%= form.label :business_name %>
        <%= form.text_field :business_name, class: "form-control" %>
      </div>

      <div class="field col-md-6">
        <%= form.label :business_type %>
        <%= form.select :business_type,
                        ["Fashion", "Beauty", "Electronics", "Food & Grocery", "Services", "Other"],
                        { include_blank: "Select business type" },
                        class: "form-control" %>
      </div>

      <div class="field col-md-6">
        <%= form.label :sell_in_store %>
        <%= form.select :sell_in_store, [["Yes", true], ["No", false]], { include_blank: "Select an option" }, class: "form-control" %>
      </div>

      <div class="field col-md-12">
        <%= form.label :business_link %>
        <%= form.text_field :business_link, class: "form-control" %>
      </div>

      <div class="field col-md-12">
        <%= form.label :intent %>
        <%= form.select :intent,
                        Inquiry::INTENT_OPTIONS.map { |value| [value == "need_both" ? "Need both POS and online store" : value.humanize, value] },
                        { include_blank: "Select an option" },
                        class: "form-control" %>
      </div>
      <% if inquiry.new_record? %>
        <div class="field col-12">
          <%= recaptcha_v3(action: "inquiry_submit", turbo: true) %>
        </div>
      <% end %>
      <div class="actions col-12 pt-2">
        <%= form.submit 'Submit', class: "btn btn-namarunu w-100" %>
      </div>
    </div>
  <% end %>
