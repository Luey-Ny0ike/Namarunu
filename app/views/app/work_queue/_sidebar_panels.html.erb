<div class="card">
  <div class="card-header py-3">
    <div class="fw-semibold">Quick Info</div>
    <div class="small text-muted">Key details while you work this lead.</div>
  </div>
  <div class="card-body py-3">
    <dl class="row mb-0 small g-2">
      <dt class="col-5 text-muted">Phone</dt>
      <dd class="col-7 mb-0 text-break">
        <% if primary_contact&.phone.present? %>
          <%= link_to primary_contact.phone, "tel:#{primary_contact.phone}", class: "fw-semibold text-decoration-none" %>
        <% else %>
          -
        <% end %>
      </dd>

      <dt class="col-5 text-muted">Location</dt>
      <dd class="col-7 mb-0"><%= current_lead.location.presence || "-" %></dd>

      <dt class="col-5 text-muted">Last contacted</dt>
      <dd class="col-7 mb-0"><%= current_lead.last_contacted_at ? l(current_lead.last_contacted_at, format: :short) : "-" %></dd>

      <dt class="col-5 text-muted">Last outcome</dt>
      <dd class="col-7 mb-0">
        <% if last_call_attempt.present? %>
          <% outcome = last_call_attempt.metadata["outcome"] || last_call_attempt.metadata[:outcome] %>
          <div><%= outcome.to_s.humanize.presence || "Unknown" %></div>
          <div class="small text-muted"><%= l(last_call_attempt.occurred_at, format: :short) %></div>
        <% else %>
          -
        <% end %>
      </dd>
    </dl>
  </div>
</div>

<div class="card">
  <div class="card-header py-3">
    <div class="fw-semibold">Actions</div>
    <div class="small text-muted">Next best actions for this lead.</div>
  </div>
  <div class="card-body p-3 d-grid gap-2">
    <%= link_to "Book demo", app_lead_path(current_lead, anchor: "book-demo"), class: "btn btn-outline-primary w-100" %>
  </div>
</div>

<div class="card">
  <div class="card-header py-3">
    <div class="fw-semibold">More</div>
    <div class="small text-muted">Status updates and conversion actions.</div>
  </div>
  <div class="card-body p-3">
    <div class="dropdown">
      <button class="btn btn-outline-dark dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        More actions
      </button>
      <ul class="dropdown-menu w-100">
        <li><%= link_to "Create Invoice", new_invoice_path(lead_id: current_lead.id), class: "dropdown-item" %></li>
        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#awaitingCommitmentModal">Awaiting commitment</button></li>
        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#invoiceSentModal">Mark Invoice Sent</button></li>
        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#confirmPaymentModal">Confirm Payment (Won)</button></li>
        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#markLostModal">Mark Lost</button></li>
        <li><button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#releaseNextModal">Release + Next</button></li>
      </ul>
    </div>
  </div>
</div>

<div class="card d-none d-lg-block">
  <div class="card-body p-2">
    <div class="d-none d-lg-flex gap-2">
      <% if prev_lead_id.present? %>
        <%= link_to "Prev", app_work_queue_path(lead_id: prev_lead_id), class: "btn btn-sm btn-outline-secondary flex-fill" %>
      <% else %>
        <button class="btn btn-sm btn-outline-secondary flex-fill" disabled>Prev</button>
      <% end %>

      <% if next_lead_id.present? %>
        <%= link_to "Next", app_work_queue_path(lead_id: next_lead_id), class: "btn btn-sm btn-outline-secondary flex-fill" %>
      <% else %>
        <button class="btn btn-sm btn-outline-secondary flex-fill" disabled>Next</button>
      <% end %>

      <%= link_to "Details", app_lead_path(current_lead), class: "btn btn-sm btn-dark flex-fill" %>
    </div>
  </div>
</div>
