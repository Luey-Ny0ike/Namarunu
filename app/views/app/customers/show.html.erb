<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <div>
    <h1 class="h3 mb-1"><%= @customer.name %></h1>
    <div><span class="badge <%= account_status_badge_class(@customer.status) %>"><%= @customer.status.humanize %></span></div>
  </div>
  <%= link_to "Back to Customers", app_customers_path(status: @customer.status == "cancelled" ? "cancelled" : @customer.status), class: "btn btn-outline-secondary" %>
</div>

<div class="row g-3">
  <div class="col-12 col-lg-7">
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Profile Snapshot</h2>
        <dl class="row mb-0 small g-2">
          <dt class="col-5 text-muted">Status</dt>
          <dd class="col-7 mb-0"><%= @customer.status.humanize %></dd>

          <dt class="col-5 text-muted">Owner</dt>
          <dd class="col-7 mb-0"><%= @customer_owner&.full_name.presence || @customer_owner&.email_address || "-" %></dd>

          <dt class="col-5 text-muted">Industry</dt>
          <dd class="col-7 mb-0"><%= @customer.industry.presence || "-" %></dd>

          <dt class="col-5 text-muted">Location</dt>
          <dd class="col-7 mb-0"><%= @customer.location.presence || "-" %></dd>

          <dt class="col-5 text-muted">Instagram</dt>
          <dd class="col-7 mb-0">
            <%= @customer.instagram_handle.presence || "-" %>
            <% if @customer.instagram_url.present? %>
              <div><%= link_to @customer.instagram_url, @customer.instagram_url, target: "_blank", rel: "noopener", class: "small" %></div>
            <% end %>
          </dd>

          <dt class="col-5 text-muted">TikTok</dt>
          <dd class="col-7 mb-0">
            <%= @customer.tiktok_handle.presence || "-" %>
            <% if @customer.tiktok_url.present? %>
              <div><%= link_to @customer.tiktok_url, @customer.tiktok_url, target: "_blank", rel: "noopener", class: "small" %></div>
            <% end %>
          </dd>

          <dt class="col-5 text-muted">Facebook</dt>
          <dd class="col-7 mb-0">
            <% if @customer.facebook_url.present? %>
              <%= link_to @customer.facebook_url, @customer.facebook_url, target: "_blank", rel: "noopener", class: "small text-break" %>
            <% else %>
              -
            <% end %>
          </dd>
        </dl>
      </div>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h2 class="h5 mb-3">Overview</h2>
        <%= render "form", customer: @customer, industry_options: @industry_options %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
          <h2 class="h5 mb-0">Contacts</h2>
          <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#addContactModal">Add contact</button>
        </div>

        <% if @contacts.any? %>
          <div class="row g-3">
            <% @contacts.each do |contact| %>
              <div class="col-12">
                <div class="border rounded-3 p-3">
                  <%= form_with model: contact,
                                url: app_customer_contact_path(@customer, contact),
                                method: :patch,
                                local: true,
                                class: "row g-2" do |form| %>
                    <div class="col-12 col-md-6">
                      <%= form.label :name, class: "form-label small text-muted" %>
                      <%= form.text_field :name, class: "form-control" %>
                    </div>
                    <div class="col-12 col-md-6">
                      <%= form.label :role, class: "form-label small text-muted" %>
                      <%= form.text_field :role, class: "form-control" %>
                    </div>
                    <div class="col-12 col-md-6">
                      <%= form.label :phone, class: "form-label small text-muted" %>
                      <%= form.text_field :phone, class: "form-control" %>
                    </div>
                    <div class="col-12 col-md-6">
                      <%= form.label :email, class: "form-label small text-muted" %>
                      <%= form.email_field :email, class: "form-control" %>
                    </div>
                    <div class="col-12 d-flex gap-2 justify-content-end">
                      <%= link_to "Delete",
                                  app_customer_contact_path(@customer, contact),
                                  data: { turbo_method: :delete, turbo_confirm: "Delete this contact?" },
                                  class: "btn btn-sm btn-outline-danger" %>
                      <%= form.submit "Save", class: "btn btn-sm btn-outline-primary" %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">No contacts added yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5 mb-3">Linked Lead</h2>
        <% if @lead.present? %>
          <div class="border rounded-3 p-3">
            <div class="fw-semibold mb-1"><%= @lead.business_name %></div>
            <div class="small text-muted">Status: <%= @lead.status.humanize %></div>
            <div class="small text-muted">Industry: <%= @lead.industry.presence || "-" %></div>
            <div class="small text-muted mb-2">Location: <%= @lead.location.presence || "-" %></div>
            <%= link_to "Open Lead", app_lead_path(@lead), class: "btn btn-sm btn-outline-secondary" %>
          </div>
        <% else %>
          <p class="text-muted mb-0">No linked lead.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="addContactModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title h5 mb-0">Add Contact</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_with model: Contact.new,
                      url: app_customer_contacts_path(@customer),
                      method: :post,
                      local: true,
                      class: "row g-2" do |form| %>
          <div class="col-12">
            <%= form.label :name, class: "form-label" %>
            <%= form.text_field :name, class: "form-control" %>
          </div>
          <div class="col-12">
            <%= form.label :role, class: "form-label" %>
            <%= form.text_field :role, class: "form-control" %>
          </div>
          <div class="col-12">
            <%= form.label :phone, class: "form-label" %>
            <%= form.text_field :phone, class: "form-control" %>
          </div>
          <div class="col-12">
            <%= form.label :email, class: "form-label" %>
            <%= form.email_field :email, class: "form-control" %>
          </div>
          <div class="col-12 d-grid">
            <%= form.submit "Add contact", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
