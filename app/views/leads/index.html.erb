<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <div>
    <h1 class="h3 mb-1">Leads</h1>
    <p class="text-muted small mb-0">Review and action pipeline leads.</p>
  </div>
  <div class="d-flex gap-2">
    <% if policy(Lead).create? %>
      <%= link_to "New Lead", new_lead_path, class: "btn btn-namarunu" %>
    <% end %>
  </div>
</div>

<% tab_base_params = request.query_parameters.except("tab", "page") %>
<div class="d-flex d-lg-none justify-content-end mb-3">
  <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="offcanvas" data-bs-target="#leadsFiltersOffcanvas" aria-controls="leadsFiltersOffcanvas">
    Filter
  </button>
</div>

<ul class="nav nav-tabs mb-3 flex-nowrap overflow-auto">
  <li class="nav-item">
    <%= link_to "My Leads", app_leads_path(tab_base_params.merge(tab: "my")), class: "nav-link #{'active' if @tab == 'my'}" %>
  </li>
  <li class="nav-item">
    <%= link_to "Unassigned", app_leads_path(tab_base_params.merge(tab: "unassigned")), class: "nav-link #{'active' if @tab == 'unassigned'}" %>
  </li>
  <li class="nav-item">
    <%= link_to "Follow-ups", app_leads_path(tab_base_params.merge(tab: "followups")), class: "nav-link #{'active' if @tab == 'followups'}" %>
  </li>
  <% if @show_all_tab %>
    <li class="nav-item">
      <%= link_to "All", app_leads_path(tab_base_params.merge(tab: "all")), class: "nav-link #{'active' if @tab == 'all'}" %>
    </li>
  <% end %>
</ul>

<div class="row g-3 align-items-start">
  <div class="col-lg-3 d-none d-lg-block">
    <div class="card shadow-sm position-sticky" style="top: 1rem;">
      <div class="card-body">
        <h2 class="h6 mb-3">Filters</h2>
        <%= render "leads/filters" %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-9">
    <%= with_automatic_pagination("leads", @page) do %>
      <div class="d-grid gap-2">
        <% @leads.each do |lead| %>
          <%= render "app/leads/lead_card", lead: lead %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="leadsFiltersOffcanvas" aria-labelledby="leadsFiltersOffcanvasLabel">
  <div class="offcanvas-header">
    <h2 class="offcanvas-title h5 mb-0" id="leadsFiltersOffcanvasLabel">Filters</h2>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <%= render "leads/filters" %>
  </div>
</div>
