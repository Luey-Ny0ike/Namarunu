<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1">New Lead</h1>
      <p class="text-muted mb-0">Capture a new CRM lead with primary contact details.</p>
    </div>
    <%= link_to "Back", app_leads_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <%= render "form", lead: @lead %>
    </div>
  </div>
</div>
