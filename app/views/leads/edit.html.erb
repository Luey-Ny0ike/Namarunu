<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1">Edit Lead</h1>
      <p class="text-muted mb-0">Update lead details, ownership, and follow-up plan.</p>
    </div>
    <%= link_to "Back", lead_path(@lead), class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <%= render "form", lead: @lead %>
    </div>
  </div>
</div>
