<div class="container py-4">
  <% if notice.present? %>
    <div class="alert alert-info" role="alert" id="notice"><%= notice %></div>
  <% end %>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1">My Tasks</h1>
      <p class="text-muted mb-0">Checked-out leads and follow-ups due today.</p>
    </div>
    <%= link_to "Back to Leads", app_leads_path, class: "btn btn-outline-secondary" %>
  </div>

  <%= render "demo_metrics" %>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <h2 class="h5 mb-3">Checked-out Leads</h2>
      <% if @checked_out_leads.any? %>
        <div class="list-group list-group-flush">
          <% @checked_out_leads.each do |lead| %>
            <div class="list-group-item px-0">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                  <div class="fw-semibold"><%= lead.business_name %></div>
                  <div class="small text-muted">
                    Status: <%= lead.status.humanize %> • Next action: <%= lead.next_action_at ? l(lead.next_action_at, format: :short) : "-" %>
                  </div>
                </div>
                <%= link_to "Open", lead_path(lead), class: "btn btn-namarunu btn-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted mb-0">No leads are currently checked out by you.</p>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-3">Follow-ups Due</h2>
      <% if @follow_up_leads.any? %>
        <div class="list-group list-group-flush">
          <% @follow_up_leads.each do |lead| %>
            <div class="list-group-item px-0">
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                  <div class="fw-semibold"><%= lead.business_name %></div>
                  <div class="small text-muted">
                    Due: <%= lead.next_action_at ? l(lead.next_action_at, format: :short) : "-" %> • Last contacted: <%= lead.last_contacted_at ? l(lead.last_contacted_at, format: :short) : "-" %>
                  </div>
                </div>
                <%= link_to "Open", lead_path(lead), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted mb-0">No follow-ups are currently due.</p>
      <% end %>
    </div>
  </div>
</div>
