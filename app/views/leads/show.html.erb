<div class="container py-4">
  <% if notice.present? %>
    <div class="alert alert-info" role="alert" id="notice"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="alert alert-warning" role="alert"><%= alert %></div>
  <% end %>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1"><%= @lead.business_name %></h1>
      <p class="text-muted mb-0">Lead profile and activity timeline.</p>
    </div>
    <div class="d-flex gap-2">
      <% if @lead.converted_account.present? %>
        <%= link_to "View Account", account_path(@lead.converted_account), class: "btn btn-outline-secondary" %>
      <% end %>
      <% if policy(@lead).convert? %>
        <%= button_to "Convert Lead", convert_lead_path(@lead), method: :post, class: "btn btn-success" %>
      <% end %>
      <% if policy(@lead).edit? %>
        <%= link_to "Edit", edit_lead_path(@lead), class: "btn btn-namarunu" %>
      <% end %>
      <%= link_to "Back", leads_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <% if policy(@lead).update? %>
        <div class="border rounded-3 p-3 mb-4">
          <h2 class="h5 mb-3">Log Call Attempt</h2>
          <%= form_with url: log_call_attempt_lead_path(@lead), method: :post, local: true, scope: :call_attempt, class: "row g-2 align-items-end" do |form| %>
            <div class="col-md-4">
              <%= form.label :outcome, class: "form-label" %>
              <%= form.select :outcome,
                              options_for_select(Lead::CALL_OUTCOMES.keys.map { |value| [value.to_s.humanize, value] }),
                              { include_blank: "Select outcome" },
                              class: "form-select",
                              required: true %>
            </div>
            <div class="col-md-4">
              <%= form.label :follow_up_at, "Follow-up at (for Follow up outcome)", class: "form-label" %>
              <%= form.datetime_local_field :follow_up_at, class: "form-control" %>
            </div>
            <div class="col-md-4">
              <%= form.label :notes, class: "form-label" %>
              <%= form.text_field :notes, class: "form-control", placeholder: "Optional notes" %>
            </div>
            <div class="col-12 d-grid d-md-flex justify-content-md-end">
              <%= form.submit "Log Call Attempt", class: "btn btn-namarunu" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if policy(@lead).update? %>
        <div class="border rounded-3 p-3 mb-4">
          <h2 class="h5 mb-3">Book Demo</h2>
          <%= form_with url: book_demo_lead_path(@lead), method: :post, local: true, scope: :demo, class: "row g-2 align-items-end" do |form| %>
            <div class="col-md-3">
              <%= form.label :scheduled_at, "Scheduled at", class: "form-label" %>
              <%= form.datetime_local_field :scheduled_at, class: "form-control", required: true %>
            </div>
            <div class="col-md-2">
              <%= form.label :duration_minutes, class: "form-label" %>
              <%= form.number_field :duration_minutes, class: "form-control", min: 1, step: 1, value: 30, required: true %>
            </div>
            <div class="col-md-3">
              <%= form.label :demo_link, class: "form-label" %>
              <%= form.url_field :demo_link, class: "form-control", placeholder: "https://meet.example.com/..." %>
            </div>
            <div class="col-md-2">
              <%= form.label :assigned_to_user_id, "Assign to", class: "form-label" %>
              <%= form.select :assigned_to_user_id,
                              options_for_select(@assignable_users.map { |user| [user.full_name.presence || user.email_address, user.id] }, Current.user.id),
                              {},
                              class: "form-select",
                              disabled: Current.user.sales_rep? %>
            </div>
            <div class="col-md-2">
              <%= form.label :account_id, "Account ID", class: "form-label" %>
              <%= form.number_field :account_id, class: "form-control", min: 1, step: 1 %>
            </div>
            <div class="col-12">
              <%= form.label :notes, class: "form-label" %>
              <%= form.text_area :notes, class: "form-control", rows: 2, placeholder: "Agenda, key stakeholders, and prep notes" %>
            </div>
            <div class="col-12 d-grid d-md-flex justify-content-md-end">
              <%= form.submit "Book Demo", class: "btn btn-namarunu" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="border rounded-3 p-3 mb-4">
        <h2 class="h5 mb-3">Demos</h2>
        <% if @demos.any? %>
          <div class="list-group list-group-flush">
            <% @demos.each do |demo| %>
              <div class="list-group-item px-0">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                  <div>
                    <div class="fw-semibold"><%= l(demo.scheduled_at, format: :short) %> • <%= demo.status.humanize %></div>
                    <div class="small text-muted">
                      Duration: <%= demo.duration_minutes %> min
                      • Assignee: <%= demo.assigned_to_user&.full_name.presence || demo.assigned_to_user&.email_address || "-" %>
                    </div>
                  </div>
                  <%= link_to "Open", demo_path(demo), class: "btn btn-outline-secondary btn-sm" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0">No demos booked for this lead yet.</p>
        <% end %>
      </div>

      <h2 class="h5 mb-2">Checkout</h2>
      <% if @active_assignment.present? %>
        <p class="mb-3">
          Checked out by
          <strong><%= @active_assignment.user.full_name.presence || @active_assignment.user.email_address %></strong>
          until <strong><%= l(@active_assignment.expires_at, format: :short) %></strong>.
        </p>
      <% else %>
        <p class="text-muted mb-3">This lead is currently available for checkout.</p>
      <% end %>

      <div class="d-flex flex-wrap gap-2">
        <% if policy(@lead).checkout? %>
          <%= button_to "Check out", checkout_lead_path(@lead), method: :patch, class: "btn btn-namarunu" %>
        <% end %>

        <% if policy(@lead).release? && @active_assignment.present? && @active_assignment.user_id == Current.user.id %>
          <%= button_to "Release", release_lead_path(@lead), method: :patch, class: "btn btn-outline-secondary" %>
        <% end %>

        <% if policy(@lead).force_release? && @active_assignment.present? %>
          <%= button_to "Force release", force_release_lead_path(@lead), method: :patch, class: "btn btn-outline-danger" %>
        <% end %>
      </div>

      <% if policy(@lead).reassign_checkout? %>
        <hr>
        <h3 class="h6 mb-3">Reassign Checkout</h3>
        <%= form_with url: reassign_checkout_lead_path(@lead), method: :patch, local: true, class: "row g-2 align-items-end" do |form| %>
          <div class="col-md-8">
            <%= form.label :user_id, "Assign to", class: "form-label" %>
            <%= form.select :user_id,
                            options_for_select(@assignable_users.map { |user| [user.full_name.presence || user.email_address, user.id] }, @active_assignment&.user_id),
                            {},
                            class: "form-select" %>
          </div>
          <div class="col-md-4">
            <%= form.submit "Reassign", class: "btn btn-namarunu w-100" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="row g-4">
        <div class="col-lg-6">
          <dl class="row mb-0">
            <dt class="col-sm-5 text-muted">Location</dt>
            <dd class="col-sm-7"><%= @lead.location.presence || "-" %></dd>

            <dt class="col-sm-5 text-muted">Industry</dt>
            <dd class="col-sm-7"><%= @lead.industry.presence || "-" %></dd>

            <dt class="col-sm-5 text-muted">Source</dt>
            <dd class="col-sm-7"><%= @lead.source.presence || "-" %></dd>

            <dt class="col-sm-5 text-muted">Owner</dt>
            <dd class="col-sm-7"><%= @lead.owner_user&.full_name || @lead.owner_user&.email_address || "Unassigned" %></dd>
          </dl>
        </div>
        <div class="col-lg-6">
          <dl class="row mb-0">
            <dt class="col-sm-5 text-muted">Status</dt>
            <dd class="col-sm-7"><%= @lead.status.humanize %></dd>

            <dt class="col-sm-5 text-muted">Temperature</dt>
            <dd class="col-sm-7"><%= @lead.temperature.humanize %></dd>

            <dt class="col-sm-5 text-muted">Next action</dt>
            <dd class="col-sm-7"><%= @lead.next_action_at ? l(@lead.next_action_at, format: :short) : "-" %></dd>

            <dt class="col-sm-5 text-muted">Last contacted</dt>
            <dd class="col-sm-7"><%= @lead.last_contacted_at ? l(@lead.last_contacted_at, format: :short) : "-" %></dd>

            <dt class="col-sm-5 text-muted">Converted</dt>
            <dd class="col-sm-7"><%= @lead.converted_at ? l(@lead.converted_at, format: :short) : "-" %></dd>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <h2 class="h5 mb-3">Contacts</h2>
      <div class="row g-3">
        <% @lead.lead_contacts.each do |contact| %>
          <div class="col-md-6">
            <div class="border rounded-3 p-3 h-100">
              <div class="fw-semibold"><%= contact.name %></div>
              <div class="small text-muted mb-2"><%= contact.role.presence || "-" %></div>
              <div><strong>Phone:</strong> <%= contact.phone.presence || "-" %></div>
              <div><strong>Email:</strong> <%= contact.email.presence || "-" %></div>
              <div><strong>Preferred:</strong> <%= contact.preferred_channel.presence&.humanize || "-" %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-3">Activity Timeline</h2>
      <% if @activities.any? %>
        <div class="list-group list-group-flush">
          <% @activities.each do |activity| %>
            <div class="list-group-item px-0">
              <div class="d-flex justify-content-between align-items-start gap-2">
                <div>
                  <div class="fw-semibold"><%= activity.timeline_label %></div>
                  <div class="small text-muted">
                    by <%= activity.actor_user.full_name.presence || activity.actor_user.email_address %>
                    <% if activity.metadata["changed_fields"].present? %>
                      • fields: <%= activity.metadata["changed_fields"].join(", ") %>
                    <% end %>
                    <% if activity.action_type == "call_attempt_logged" %>
                      • outcome: <%= activity.metadata["outcome"].to_s.humanize %>
                      <% if activity.metadata["next_action_at"].present? %>
                        • follow-up: <%= l(Time.zone.parse(activity.metadata["next_action_at"]), format: :short) %>
                      <% end %>
                      <% if activity.metadata["notes"].present? %>
                        • notes: <%= activity.metadata["notes"] %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
                <div class="small text-muted"><%= l(activity.occurred_at, format: :short) %></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted mb-0">No activity yet.</p>
      <% end %>
    </div>
  </div>
</div>
