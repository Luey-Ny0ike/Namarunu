<div class="container wizard-steps-layout">
  <h3>Get Started</h3>
  <p class="mb-4">Tell us how to reach you and we will get in touch quickly.</p>

  <%= form_with model: @inquiry, url: inquiries_path, local: true do |form| %>
    <div class="row justify-content-center">
      <% if @inquiry.errors.any? %>
        <div id="error_explanation" class="col-md-8">
          <h2><%= pluralize(@inquiry.errors.count, "error") %> prevented your submission:</h2>
          <ul>
            <% @inquiry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div style="display:none;">
        <%= form.label :website, "Website" %>
        <%= form.text_field :website, tabindex: -1, autocomplete: "off" %>
      </div>

      <div class="field col-md-8">
        <%= form.label :full_name, "Full name" %>
        <%= form.text_field :full_name, class: "form-control", required: true %>
      </div>

      <div class="field col-md-8 mt-2">
        <%= form.label :phone_number, "Phone number" %>
        <%= form.telephone_field :phone_number, class: "form-control", required: true %>
      </div>

      <div class="field col-md-8 mt-2">
        <%= form.label :business_name, "Business name" %>
        <%= form.text_field :business_name, class: "form-control", required: true %>
      </div>

      <div class="field col-md-8 mt-2">
        <%= form.label :email, "Email (optional)" %>
        <%= form.email_field :email, class: "form-control" %>
      </div>

      <div class="field col-md-8 mt-3">
        <%= form.submit "Continue", class: "btn btn-outline-success next-button" %>
      </div>
    </div>
  <% end %>
</div>
