<div class="container py-4">
  <% if notice.present? %>
    <div class="alert alert-info" role="alert" id="notice"><%= notice %></div>
  <% end %>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h1 class="h3 mb-1"><%= @inquiry.full_name %></h1>
      <p class="text-muted mb-0">Lead details and marketing context.</p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to 'Edit', edit_inquiry_path(@inquiry), class: 'btn btn-namarunu' %>
      <%= link_to 'Back', inquiries_path, class: 'btn btn-outline-secondary' %>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <div class="row g-4">
        <div class="col-lg-6">
          <dl class="row mb-0">
            <dt class="col-sm-5 text-muted">Full name</dt>
            <dd class="col-sm-7 fw-semibold"><%= @inquiry.full_name %></dd>

            <dt class="col-sm-5 text-muted">Phone number</dt>
            <dd class="col-sm-7"><%= @inquiry.phone_number %></dd>

            <dt class="col-sm-5 text-muted">Email</dt>
            <dd class="col-sm-7"><%= @inquiry.email.presence || '-' %></dd>

            <dt class="col-sm-5 text-muted">Business name</dt>
            <dd class="col-sm-7"><%= @inquiry.business_name %></dd>

            <dt class="col-sm-5 text-muted">Business type</dt>
            <dd class="col-sm-7"><%= @inquiry.business_type.presence || '-' %></dd>

            <dt class="col-sm-5 text-muted">Sell in-store</dt>
            <dd class="col-sm-7"><%= @inquiry.sell_in_store.nil? ? '-' : (@inquiry.sell_in_store ? 'Yes' : 'No') %></dd>
          </dl>
        </div>
        <div class="col-lg-6">
          <dl class="row mb-0">
            <dt class="col-sm-5 text-muted">Intent</dt>
            <dd class="col-sm-7"><%= @inquiry.intent.present? ? @inquiry.intent.humanize : '-' %></dd>

            <dt class="col-sm-5 text-muted">Business link</dt>
            <dd class="col-sm-7"><%= @inquiry.business_link.presence || '-' %></dd>

            <dt class="col-sm-5 text-muted">Source</dt>
            <dd class="col-sm-7"><%= @inquiry.source %></dd>

            <dt class="col-sm-5 text-muted">Status</dt>
            <dd class="col-sm-7"><%= @inquiry.status %></dd>
          </dl>
        </div>
        <div class="col-12">
          <div class="border rounded-3 p-3 bg-light">
            <div class="text-muted text-uppercase small fw-semibold mb-2">UTM Tracking</div>
            <div class="row g-2">
              <div class="col-md-4"><strong>Source:</strong> <%= @inquiry.utm_source.presence || '-' %></div>
              <div class="col-md-4"><strong>Medium:</strong> <%= @inquiry.utm_medium.presence || '-' %></div>
              <div class="col-md-4"><strong>Campaign:</strong> <%= @inquiry.utm_campaign.presence || '-' %></div>
              <div class="col-md-4"><strong>Term:</strong> <%= @inquiry.utm_term.presence || '-' %></div>
              <div class="col-md-8"><strong>Content:</strong> <%= @inquiry.utm_content.presence || '-' %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
