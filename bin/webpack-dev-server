#!/usr/bin/env ruby

require "psych"

module Psych
  class << self
    alias_method :_original_load, :load
    alias_method :_original_load_file, :load_file

    def load(yaml, *args, **kwargs)
      _original_load(yaml, *args, aliases: true)
    end

    def load_file(filename, *args, **kwargs)
      _original_load_file(filename, *args, aliases: true)
    end
  end
end

ENV["RAILS_ENV"] ||= ENV["RACK_ENV"] || "development"
ENV["NODE_ENV"]  ||= "development"

require "pathname"
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../../Gemfile",
  Pathname.new(__FILE__).realpath)

require "bundler/setup"

require "webpacker"
require "webpacker/dev_server_runner"

APP_ROOT = File.expand_path("..", __dir__)
Dir.chdir(APP_ROOT) do
  Webpacker::DevServerRunner.run(ARGV)
end
