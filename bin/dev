#!/usr/bin/env ruby

ENV["RAILS_ENV"] ||= "development"

require "logger"
require "active_support"
require "bundler/setup"
require "fileutils"

# Check if foreman is available
def foreman_available?
  system("which foreman > /dev/null 2>&1")
end

# Start the development server
if foreman_available?
  puts "Starting Rails app with foreman..."
  exec("foreman start -f Procfile.dev")
else
  puts "Foreman not found. Starting Rails server and webpack-dev-server separately..."
  
  # Start webpack-dev-server in background
  fork do
    exec("./bin/webpack-dev-server")
  end
  
  # Start Rails server in foreground
  exec("bundle exec puma -C config/puma.rb")
end
